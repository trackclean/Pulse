{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-write",
    "fs:allow-write-file",
    "fs:allow-read",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download"
  ]
}
