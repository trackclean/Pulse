{
  "name": "clean-track-buddy",
  "version": "1.0.9",
  "description": "Local-first audio sample cleaner and organizer built with Tauri and React",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "audio",
    "sample",
    "organizer",
    "cleaner",
    "tauri",
    "react",
    "music-production",
    "desktop-app"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trackclean/Pulse.git"
  },
  "homepage": "https://github.com/trackclean/Pulse",
  "bugs": {
    "url": "https://github.com/trackclean/Pulse/issues"
  },
  "author": "trackclean",
  "scripts": {
    "dev": "node -r ./scripts/vite-crypto-polyfill.js ./node_modules/vite/bin/vite",
    "dev:app": "cross-env VITE_APP_BUILD=true node -r ./scripts/vite-crypto-polyfill.js ./node_modules/vite/bin/vite",
    "build": "vite build",
    "build:app": "cross-env VITE_APP_BUILD=true vite build && node scripts/flatten-dist.js",
    "build:website": "cross-env GITHUB_PAGES=true vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "generate-manifest": "node scripts/generate-test-manifest.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:all": "npm run lint && npm run test:e2e",
    "test:tauri": "playwright test --config playwright.tauri.config.ts",
    "test:tauri:report": "playwright show-report playwright-report-tauri",
    "tauri:build:debug": "tauri build --debug"
  },
